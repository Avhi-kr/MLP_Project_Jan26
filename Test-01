nprint(f\"🏆 ENSEMBLE VALIDATION ACCURACY: {ensemble_acc:.4f} 🏆\")\nprint(\"---------------------------------------------------------\")\nprint(\"\\nDetailed Classification Report (Val Set):\")\nprint(classification_report(y_val, final_val_pred, target_names=[f\"Class {c}\" for c in le.classes_]))\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 9. Final Inference & Submission Generation\nNow we retrain the best algorithms on the ENTIRE training dataset so they have maximum information, predict on the test set, and finally build our `submission.csv`.\n","metadata":{}},{"cell_type":"code","source":"print(\"Retraining models on 100% of the training data...\")\n# Because we used RandomizedSearchCV, best_lr is already fit, but we want to fit it on everything\nbest_lr.fit(X, y)\nsgd.fit(X, y)\nlgb_model.fit(X, y)\nxgb_model.fit(X, y)\nnb.fit(X, y)\n\nprint(\"Inferencing on unseen Test Data...\")\nnb_test  = nb.predict_proba(X_test)\nlr_test  = best_lr.predict_proba(X_test)\nsgd_test = sgd.predict_proba(X_test)\nlgb_test = lgb_model.predict_proba(X_test)\nxgb_test = xgb_model.predict_proba(X_test)\n\n# Final Soft Voting\nfinal_test_prob = (w_nb * nb_test + w_lr * lr_test + w_sgd * sgd_test + w_lgb * lgb_test + w_xgb * xgb_test)\ntest_predictions = np.argmax(final_test_prob, axis=1)\n\n# Inverse transform to original labels (0, 1, 2, 3)\ntest_labels = le.inverse_transform(test_predictions)\n\n# Save Submission\nsample['label'] = test_labels\nsample.to_csv('submission.csv', index=False)\nprint(\"submission.csv successfully generated!\")\nprint(\"\\nTest predictions distribution:\")\nprint(sample['label'].value_counts(normalize=True).round(3) * 100)\n","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}